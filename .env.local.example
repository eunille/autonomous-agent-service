# Backend API URL
# Local development:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Production (Render):
# NEXT_PUBLIC_API_BASE_URL=https://autonomous-agent-service.onrender.com

# API key — must match API_SECRET_KEY in backend .env
NEXT_PUBLIC_API_KEY=your-api-secret-key-here

# Dashboard password — set this to protect the /dashboard route
# If left empty, the dashboard is open to anyone with the URL
NEXT_PUBLIC_DASHBOARD_PASSWORD=your-dashboard-password-here
